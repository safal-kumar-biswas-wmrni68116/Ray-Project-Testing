{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2015",
    "module": "ESNext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmitOnError": false,
    "jsx": "react",
    "paths": {
      "ray": [
        "./node_modules/@ray-js/ray"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "typeRoots": [
      "./typings"
    ]
  },
  "include": [
    "src/**/*.*",
    ".ray/**/*.*",
    "typings"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public"
  ]
}
